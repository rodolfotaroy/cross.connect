# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://xc_user:xc_password@localhost:5433/cross_connect?schema=public"

# ── API Server ─────────────────────────────────────────────────────────────────
# NOTE: Docker sets API_PORT=3001 internally (mapped to host 3100:3001).
#       For local pnpm dev, keep this at 3100 to avoid conflicting with other apps.
API_PORT=3100
API_HOST=0.0.0.0
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-256-bit-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-random-256-bit-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ── S3-compatible Storage ──────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="cross-connect-docs"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
# Public URL used to build presigned download links
S3_PUBLIC_URL="http://localhost:9000"

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# Web dev server runs on port 3210 (hardcoded in apps/web/package.json)
NEXT_PUBLIC_API_URL="http://localhost:3100"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3210"
# Docker only: server-side URL so next-auth can reach the API container
# over the internal Docker network. Not needed for local pnpm dev.
# API_INTERNAL_URL="http://api:3001"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must match the web dev URL above.
CORS_ORIGINS="http://localhost:3210"

# ── pg-boss Background Jobs ────────────────────────────────────────────────────
JOBS_SCHEMA="xc_jobs"

# ── Rate Limiting ──────────────────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
