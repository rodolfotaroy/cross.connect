  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@vitest/coverage-v8": "^3.0.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.7"
  }
